BLUEPRINT_API_BASE_URL=https://www.workflowblueprint.io
EXTERNAL_API_KEY=blueprint_live_replace_me
BLUEPRINT_TIMEOUT_MS=12000

RESEND_API_KEY=re_live_replace_me
BRIEFING_FROM_EMAIL=briefing@updates.example.com
BRIEFING_TO_EMAILS=founder@example.com

CRON_SECRET=replace_with_32_plus_character_random_secret
BRIEFING_SUBJECT_PREFIX=Morning Brief
BRIEFING_MAX_ITEMS=10

# Upstash Redis REST or Vercel KV REST. Used to prevent duplicate sends on cron retries.
BRIEFING_IDEMPOTENCY_REDIS_REST_URL=https://your-kv.upstash.io
BRIEFING_IDEMPOTENCY_REDIS_REST_TOKEN=replace_me
BRIEFING_IDEMPOTENCY_SENT_TTL_SECONDS=129600
BRIEFING_IDEMPOTENCY_LOCK_TTL_SECONDS=1800
